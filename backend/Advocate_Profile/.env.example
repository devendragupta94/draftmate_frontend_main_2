# Environment
ENVIRONMENT=production
FRONTEND_URL_PROD=https://draftmate.ai
FRONTEND_URL_DEV=http://localhost:5173

# JWT
JWT_SECRET=your_very_strong_secret_key_here_change_this

# PostgreSQL (RDS)
POSTGRES_HOST=your-rds-instance.abc123.region.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_DB=draftmate
POSTGRES_USER=db_user
POSTGRES_PASSWORD=your_db_password

# OR use DSN
# POSTGRES_DSN=postgresql://user:pass@host:5432/dbname

# S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET_NAME=draftmate-advocate-files
AWS_REGION=ap-south-1

# Notification Service
NOTIFICATION_SERVICE_URL=http://127.0.0.1:8015
